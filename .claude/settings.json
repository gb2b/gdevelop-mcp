{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install -D *)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(npm test)",
      "Bash(npm test -- *)",
      "Bash(npm run test:watch)",
      "Bash(npm run dev)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc)",
      "Bash(npx vitest *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Read(*)",
      "Edit(src/**)",
      "Edit(test/**)",
      "Edit(.claude/**)",
      "Edit(*.md)",
      "Edit(*.json)",
      "Edit(*.ts)",
      "Write(src/**)",
      "Write(test/**)",
      "Write(.claude/**)",
      "Write(*.md)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(npm publish *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(sudo *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(npm publish)",
      "Bash(rm *)",
      "Write(dist/**)",
      "Write(node_modules/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck-on-src-change.sh"
          }
        ]
      }
    ]
  }
}
