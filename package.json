{
  "name": "gdevelop-mcp",
  "version": "0.10.0",
  "description": "MCP server for GDevelop project introspection and validation",
  "type": "module",
  "bin": {
    "gdevelop-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@napi-rs/canvas": "^1.0.0",
    "gdexporter": "^4.0.0-beta7",
    "puppeteer": "^25.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
