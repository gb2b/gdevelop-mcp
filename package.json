{
  "name": "gdevelop-mcp",
  "version": "0.20.0",
  "description": "MCP server for GDevelop project introspection, editing, and preview — backed by the canonical 4ian/GDevelop GitHub repo.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gdevelop",
    "game-dev",
    "claude-code",
    "anthropic",
    "code-introspection"
  ],
  "homepage": "https://github.com/gb2b/gdevelop-mcp#readme",
  "bugs": {
    "url": "https://github.com/gb2b/gdevelop-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gb2b/gdevelop-mcp.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gdevelop-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"{src,test}/**/*.{ts,js}\" \"*.md\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,js}\" \"*.md\"",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "audit:supply-chain": "pnpm audit --audit-level=high --prod",
    "inspect": "pnpm dlx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@napi-rs/canvas": "^1.0.0",
    "gdexporter": "^4.0.0-beta7",
    "puppeteer": "^25.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@napi-rs/canvas",
      "esbuild",
      "puppeteer"
    ]
  }
}
