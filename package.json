{
  "name": "gdevelop-mcp",
  "version": "0.10.0",
  "description": "MCP server for GDevelop project introspection and validation",
  "type": "module",
  "bin": {
    "gdevelop-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"{src,test}/**/*.{ts,js}\" \"*.md\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,js}\" \"*.md\"",
    "check": "npm run typecheck && npm run lint && npm test",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@napi-rs/canvas": "^1.0.0",
    "gdexporter": "^4.0.0-beta7",
    "puppeteer": "^25.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
